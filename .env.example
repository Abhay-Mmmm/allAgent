# ══════════════════════════════════════════════════════════════════════════════
#  allAgent — Environment Variable Template
#  Location: project root (allAgent/.env.example)
#
#  HOW TO USE:
#    cp .env.example .env
#    Fill in every value marked with <...>
#
#  This file is safe to commit — it contains NO real secrets.
# ══════════════════════════════════════════════════════════════════════════════


# ── Database (Railway PostgreSQL) ─────────────────────────────────────────────
# Railway provides DATABASE_URL automatically when you add a Postgres plugin.
# Copy it from: Railway dashboard → your Postgres service → Variables tab
# Always append ?sslmode=require for Railway production connections.
DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE>?sslmode=require

# Local development override (not needed if using docker-compose):
# DATABASE_URL=postgresql://allagent:allagent_local@localhost:5432/allagent


# ── App Environment ───────────────────────────────────────────────────────────
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR


# ── LLM — Groq (OpenAI-compatible) ───────────────────────────────────────────
# Sign up at https://console.groq.com → API Keys
GROQ_API_KEY=gsk_<your_groq_api_key>


# ── VAPI Voice AI ─────────────────────────────────────────────────────────────
# Sign up at https://dashboard.vapi.ai
# API Key:           Dashboard → Account → API Keys
# Phone Number ID:   Dashboard → Phone Numbers → copy the ID of your number
# Server URL:        Your deployed backend URL + /api/vapi-webhook
#                    For local dev use ngrok: ngrok http 8000
VAPI_API_KEY=<your_vapi_api_key>
VAPI_PHONE_NUMBER_ID=<your_vapi_phone_number_id>
VAPI_SERVER_URL=https://<your-domain>.com/api/vapi-webhook
VAPI_WEBHOOK_SECRET=<any_random_secret_string>


# ── Frontend — Vite Variables (VITE_ prefix exposes them to the browser) ──────

# Backend API base URLs (update for production deployment)
VITE_APP_TITLE=allAgent
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_BASE_URL=ws://localhost:8000/ws

# Feature flags
VITE_ENABLE_VOICE_CALLS=true
VITE_ENABLE_DOCUMENT_SCANNER=true
VITE_ENABLE_MULTILINGUAL=false

# Debug mode (set to true for verbose frontend logging)
VITE_DEBUG_MODE=false

# AI keys used directly by the Vite frontend
VITE_AI_API_KEY_VOICE=<your_voice_api_key>
VITE_AI_API_KEY_CHAT=<your_chat_api_key>
