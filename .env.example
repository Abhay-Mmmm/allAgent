# ══════════════════════════════════════════════════════════════════════════════
#  allAgent — Outbound AI Sales Calling Platform
#  Single root .env — loaded by ALL services (backend, frontend, scripts)
#  Location: project root (allAgent/.env)
#  ⚠️  NEVER commit .env — it is gitignored.
#  Setup: copy this file to .env and fill in your values.
#         cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════


# ── Database ──────────────────────────────────────────────────────────────────
# LOCAL DEV (Docker — run once: cd backend && docker compose up -d):
DATABASE_URL=postgresql://allagent:allagent_local@localhost:5432/allagent

# RAILWAY (paste External URL from: Postgres service → Connect → Public Networking):
# DATABASE_URL=postgresql://postgres:PASSWORD@monorail.proxy.rlwy.net:PORT/railway?sslmode=require
# NOTE: When deployed ON Railway, DATABASE_URL is auto-injected — no need to set it there.


# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
# CORS — comma-separated list of allowed origins, or * for all
CORS_ORIGINS_RAW=*


# ── Groq LLM (https://console.groq.com/keys) ─────────────────────────────────
GROQ_API_KEY=


# ── Twilio (https://console.twilio.com) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Public HTTPS URL Twilio will POST webhooks to (ngrok for local dev):
# Twilio calls: {TWILIO_BASE_URL}/api/twilio/voice
#               {TWILIO_BASE_URL}/api/twilio/status
TWILIO_BASE_URL=https://your-ngrok-or-railway-url.com


# ── Frontend — Vite (VITE_ prefix exposes variables to the browser) ───────────
VITE_APP_TITLE=allAgent
# Local dev:
VITE_API_BASE_URL=http://localhost:8000/api
# Railway backend deployed:
# VITE_API_BASE_URL=https://YOUR-BACKEND.up.railway.app/api
