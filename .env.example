# ══════════════════════════════════════════════════════════════════════════════
#  allAgent — Outbound AI Sales Calling Platform
#  Environment Variables
#  ⚠️  NEVER commit this file — it is gitignored.
#  Copy .env.example to .env and fill in your actual values.
# ══════════════════════════════════════════════════════════════════════════════


# ── Database (Railway PostgreSQL) ─────────────────────────────────────────────
# Railway provides this automatically when you add a Postgres plugin.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Always add ?sslmode=require for Railway production connections.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# Local dev:
# DATABASE_URL=postgresql://allagent:allagent_local@localhost:5432/allagent


# ── App Environment ───────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# CORS — comma-separated list of allowed origins (use * for development)
CORS_ORIGINS_RAW=*


# ── LLM — Groq (ONLY LLM provider) ──────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here


# ── VAPI Voice AI (ONLY voice provider) ──────────────────────────────────────
# Dashboard: https://dashboard.vapi.ai
VAPI_API_KEY=your_vapi_api_key_here
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here
# Your public webhook URL (must be HTTPS — use ngrok for local dev)
VAPI_SERVER_URL=https://your-domain.com/api/vapi-webhook
VAPI_WEBHOOK_SECRET=your_webhook_secret_here


# ── Frontend — Vite Variables (VITE_ prefix exposes them to the browser) ──────
VITE_APP_TITLE=allAgent — Outbound AI Sales Platform
VITE_API_BASE_URL=http://localhost:8000/api
